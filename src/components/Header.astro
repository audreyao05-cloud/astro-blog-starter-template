---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/programs">Programs</HeaderLink>
      <HeaderLink href="/workouts">Free Workouts</HeaderLink>
      <HeaderLink href="/coaching">Coaching</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1rem;
    background: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    white-space: nowrap;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
    color: #111;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .internal-links a {
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 720px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
    }

    .internal-links {
      gap: 0.9rem;
    }
  }
</style>
