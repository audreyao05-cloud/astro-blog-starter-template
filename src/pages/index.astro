---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <BaseHead
      title="FitMom702 | Strength & Kettlebell Training"
      description="Fitness programs, kettlebell workouts, and coaching for women by Audrey at FitMom702."
    />
  </head>

  <body>

    <Header />

    <main>

      <section class="hero">
        <h1>FitMom702</h1>

        <p>
          Build strength. Build confidence.
          Kettlebell training and fitness programs designed for
          busy women who want real results.
        </p>

        <div class="buttons">
          <a href="/programs" class="btn">View Programs</a>
          <a href="/coaching" class="btn-outline">Start Coaching</a>
        </div>
      </section>

      <section class="features">

        <div class="card">
          <h2>Kettlebell Programs</h2>
          <p>
            Structured training programs designed to build glutes,
            increase strength, and improve overall fitness.
          </p>
        </div>

        <div class="card">
          <h2>Free Workouts</h2>
          <p>
            Follow along with free workouts and training ideas
            from the FitMom702 community.
          </p>
        </div>

        <div class="card">
          <h2>Coaching</h2>
          <p>
            Personalized coaching designed around your goals,
            schedule, and experience level.
          </p>
        </div>

      </section>

    </main>

    <Footer />

  </body>
</html>

<style>
.hero {
  text-align: center;
  padding: 80px 20px;
}

.hero h1 {
  font-size: 48px;
  margin-bottom: 10px;
}

.hero p {
  max-width: 600px;
  margin: auto;
  font-size: 18px;
  margin-bottom: 30px;
}

.buttons {
  display: flex;
  gap: 16px;
  justify-content: center;
}

.btn {
  background: #ff2d7a;
  color: white;
  padding: 12px 24px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 600;
}

.btn-outline {
  border: 2px solid #ff2d7a;
  color: #ff2d7a;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 600;
}

.features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
  gap: 30px;
  max-width: 900px;
  margin: auto;
  padding: 60px 20px;
}

.card {
  background: #f7f7f7;
  padding: 30px;
  border-radius: 10px;
}
</style>
